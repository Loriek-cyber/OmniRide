<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Definizione della pagina di benvenuto -->
    <welcome-file-list>
        <welcome-file>/../index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Prima servlet -->
    <servlet>
        <servlet-name>PrimaServlet</servlet-name>
        <servlet-class>com.example.PrimaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PrimaServlet</servlet-name>
        <url-pattern>/prima</url-pattern>
    </servlet-mapping>

    <!-- Seconda servlet -->
    <servlet>
        <servlet-name>SecondaServlet</servlet-name>
        <servlet-class>com.example.SecondaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SecondaServlet</servlet-name>
        <url-pattern>/seconda</url-pattern>
    </servlet-mapping>

    <!-- Testingdek servlet -->
    <servlet>
        <servlet-name-name>testingdek</servlet-name-
        <servlet-class>test.testingdek</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>testingdek</servlet-name>
        <url-pattern>/testingdek</url-pattern>
    </servlet-mapping>

</web-app>name>